# 복사해서 .env.local(로컬 전용, commit 금지) / .env.prod(secret flow 대상)로 사용
# env 이름은 SPEC-004 / SPEC-007 / ARCH-001 §10 기준

# App
APP_ENV=local
CORS_ORIGINS=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:8000

# DB / Redis
DATABASE_URL=postgresql+asyncpg://gcs:gcs@localhost:5432/gcs_demo
REDIS_URL=redis://localhost:6379/0

# Auth (JWT access + httpOnly refresh cookie, ARCH-001 §11)
# prod에서는 JWT_SECRET을 32바이트 이상 랜덤 값으로 교체할 것
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=1800
REFRESH_TOKEN_TTL=1209600
# refresh token cookie — prod(https)에서는 COOKIE_SECURE=true
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# 데모 로그인 공통 password (SPEC-001 Open Issue 확정안). seed user 전원에 부여.
# 원본 Mediness credential은 seed에 반영하지 않는다.
DEMO_USER_PASSWORD=cfo-demo-2026

# Google Drive connector (SPEC-004, scope는 drive.readonly)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_SELECTED_FOLDER_ID=
GOOGLE_DRIVE_WEBHOOK_URL=
# WORK-003 sync 기본값 — 폴링 주기(webhook 불가 로컬 대안) / watch 갱신 임계 / watch TTL
DRIVE_SYNC_POLL_INTERVAL_SEC=60
DRIVE_WATCH_EXPIRING_THRESHOLD_SEC=21600
DRIVE_WATCH_TTL_SEC=86400

# open-kknaks (SPEC-007) — backend submit 측과 ai_worker 측이 같은 값을 공유해야 한다
OPEN_KKNAKS_BROKER_URL=
OPEN_KKNAKS_NAMESPACE=gcs-demo
OPEN_KKNAKS_PROVIDER=claude
OPEN_KKNAKS_MODEL=
OPEN_KKNAKS_QUEUE=document-classification
OPEN_KKNAKS_TIMEOUT_SEC=300

# WORK-004 AI job worker — DB 원장(ai_queue_jobs) 폴링 주기/배치/재시도 backoff
AI_JOBS_POLL_INTERVAL_SEC=5
AI_JOBS_BATCH_SIZE=5
AI_JOBS_RETRY_BACKOFF_SEC=30
# analysis_text 상한 (원문 장기 저장 금지 — task 입력 전달만)
ANALYSIS_TEXT_MAX_CHARS=20000

# ai_worker (open-kknaks ClaudeWorker)
CONCURRENCY=2
# mac 로컬: linux/arm64 claude 도구 세트 경로 (compose local의 마운트 원본)
CLAUDE_TOOLS_HOST_PATH=/Users/kknaks/.cache/axkg-live/.claude-tools
